# ============================================
# RSOS CNV Simulation - .gitignore
# ============================================

# Large raw simulated data (regenerated by code, ~2GB)
results/simulated_log2ratios.csv

# R session files
.Rproj.user
.Rhistory
.RData
.Ruserdata
.Rproj

# R package build artefacts
*.Rcheck/
*.Rproj.user/

# RStudio files
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# Compiled R code
*.o
*.so
*.dll

# R environment files
.Renviron
.Renviron.local

# macOS/Windows/Linux system files
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
._*

# Backup files
*.bak
*.tmp
*.temp

# Log files
*.log

# Output directories (optional - only if you don't want to store any results)
# results/
# figures/

# Paper build artefacts (if you add LaTeX later)
paper/*.aux
paper/*.log
paper/*.out
paper/*.pdf
paper/*.blg
paper/*.bbl
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk

# Zenodo archive files (if any)
*.zip
*.tar.gz
